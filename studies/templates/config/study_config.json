    }
  ],

  "required_files": {
    "files": [
      {
        "file_name": "rtsm_actuals.csv",
        "location": "data_drops/{data_drop_date}/",
        "criticality": "critical"
      },
      {
        "file_name": "erp_inventory.csv",
        "location": "data_drops/{data_drop_date}/",
        "criticality": "critical"
      },
      {
        "file_name": "ctms_plan.csv",
        "location": "data_drops/{data_drop_date}/",
        "criticality": "critical"
      },
      {
        "file_name": "site_inventory.csv",
        "location": "data_drops/{data_drop_date}/",
        "criticality": "critical"
      }
    ]
  },

  "schemas": {
    "ctms_plan": {
      "required_columns": ["site_id", "country_code", "record_type", "record_date"],
      "optional_columns": ["planned_enrollment", "actual_enrollment", "site_status", "visit_type", "visit_window_days"],
      "column_types": {
        "site_id": "text", "country_code": "text", "record_type": "text",
        "record_date": "date", "planned_enrollment": "number",
        "actual_enrollment": "number", "site_status": "text",
        "visit_type": "text", "visit_window_days": "number"
      },
      "date_formats": { "record_date": "DD-MMM-YYYY" }
    },
    "erp_inventory": {
      "required_columns": ["item_id", "location", "record_type", "quantity", "record_date"],
      "optional_columns": ["lot_number", "expiry_date", "order_id", "shipment_id", "status", "origin", "destination"],
      "column_types": {
        "item_id": "text", "location": "text", "record_type": "text",
        "quantity": "number", "record_date": "date", "lot_number": "text",
        "expiry_date": "date", "order_id": "text", "shipment_id": "text",
        "status": "text", "origin": "text", "destination": "text"
      },
      "date_formats": { "record_date": "DD-MMM-YYYY", "expiry_date": "DD-MMM-YYYY" }
    },
    "site_inventory": {
      "required_columns": ["Site", "item_id", "On_Hand_Qty", "Weekly_Demand", "Min_Reorder_Point", "Max_Reorder_Point"],
      "optional_columns": [],
      "column_types": {
        "Site": "text", "item_id": "text", "On_Hand_Qty": "number",
        "Weekly_Demand": "number", "Min_Reorder_Point": "number", "Max_Reorder_Point": "number"
      },
      "date_formats": {}
    },
    "rtsm_actuals": {
      "required_columns": ["site_id", "country_code", "event_type", "item_id"],
      "optional_columns": ["arm_id", "event_date", "quantity", "patient_id", "lot_number", "notes"],
      "column_types": {
        "site_id": "text", "country_code": "text", "event_type": "text",
        "item_id": "text", "arm_id": "text", "event_date": "date",
        "quantity": "number", "patient_id": "text", "lot_number": "text", "notes": "text"
      },
      "date_formats": { "event_date": "DD-MMM-YYYY" }
    }
  },

  "assumptions": {
    "screen_failure_rate_pct": "TODO: e.g. 20",
    "dropout_rate_pct": "TODO: e.g. 10",
    "review_period_weeks": 4
  }
}
